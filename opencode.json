{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp"],
      "enabled": true
    },
    "figma": {
      "type": "local",
      "command": ["npx", "figma-developer-mcp", "--stdio"],
      "enabled": true
    },
    "voice": {
      "type": "local",
      "command": ["npx", "@mbailey/voice-mcp"],
      "enabled": true
    },
    "rag-web": {
      "type": "local",
      "command": ["npx", "@apify/mcp-server-rag-web-browser"],
      "enabled": false
    }
  }
}
