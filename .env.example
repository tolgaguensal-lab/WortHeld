# Datenbank (PostgreSQL)
# connection_limit=10 → max. gleichzeitige Verbindungen (Standard: 10)
# pool_timeout=10 → Sekunden bevor ein Query timeouted (Standard: 10)
DATABASE_URL="postgresql://user:password@localhost:5432/deutschquest?schema=public&connection_limit=10&pool_timeout=10"
NEXTAUTH_URL="http://localhost:3035"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Cookies: In Production mit HTTPS zwingend auf true setzen!
AUTH_SECURE_COOKIES=true

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LANGUAGE_TOOL_API_URL="https://api.languagetool.org"
TATOEBA_API_URL="https://tatoeba.org/api"
WIKTIONARY_API_URL="https://en.wiktionary.org/api"
