# ═══════════════════════════════════════════════════════════════
# Wortwende — ZimaOS Environment (Beispiel)
# → Kopiere als zimaos.env und passe Secrets an
# ═══════════════════════════════════════════════════════════════

# Datenbank
DB_PASSWORD=wortwende
DATABASE_URL="postgresql://wortwende:${DB_PASSWORD}@postgres:5432/wortwende?schema=public&connection_limit=10&pool_timeout=10"

# NextAuth
NEXTAUTH_URL="http://192.168.178.91:3035"
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_SECURE_COOKIES=false
AUTH_TRUST_HOST=true

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Open-Source Content APIs (alle lokal im Docker-Netzwerk)
LIBRETRANSLATE_URL="http://libretranslate:5000"
LANGUAGE_TOOL_API_URL="http://languagetool:8010"
PIPER_TTS_URL="http://piper-tts:10200"

# Externe Content-APIs (kostenlos, keine Keys nötig)
TATOEBA_API_URL="https://tatoeba.org/deu/api_v0"
WIKTIONARY_API_URL="https://de.wiktionary.org/api/rest_v1"
OPENTHESAURUS_API_URL="https://www.openthesaurus.de/synonyme"

# AI Tutor
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
TRANSLATION_PROVIDER="libretranslate"

# Externe APIs (Standard-Werte lassen)
LANGUAGE_TOOL_API_URL=https://api.languagetool.org
TATOEBA_API_URL=https://tatoeba.org/api
WIKTIONARY_API_URL=https://en.wiktionary.org/api
# Secure Cookies: In Production mit HTTPS zwingend auf true!
AUTH_SECURE_COOKIES=true

# Übersetzung (LibreTranslate — internes Docker-Netzwerk)
LIBRETRANSLATE_URL=http://libretranslate:5000
TRANSLATION_PROVIDER=libretranslate
