# ──────────────────────────────────────────────
# WortHeld (DeutschQuest) — ZimaOS Environment
# ──────────────────────────────────────────────
# Kopiere als zimaos.env und passe an:
#   cp zimaos.env.example zimaos.env && nano zimaos.env
#
# POSTGRES_PASSWORD wird unten als Secret definiert.
# ──────────────────────────────────────────────

# Node
NODE_ENV=production
PORT=3000

# Datenbank (PostgreSQL — internes Docker-Netzwerk, kein externer Port)
# connection_limit=10: max. gleichzeitige Verbindungen (Standard: 10)
# pool_timeout=10: Sekunden bevor ein Query timeouted (Standard: 10)
DATABASE_URL=postgresql://wortheld:${POSTGRES_PASSWORD}@wortheld-postgres:5432/wortheld?schema=public&connection_limit=10&pool_timeout=10

# PostgreSQL Passwort (hier ein sicheres Passwort eintragen!)
POSTGRES_PASSWORD=CHANGE_ME_sicheres-passwort-hier

# NextAuth
NEXTAUTH_URL=https://wortheld.guenlab.de
NEXTAUTH_SECRET=<mindestens-32-zeichen-hier-einfuegen>
AUTH_TRUST_HOST=true

# Google OAuth (optional — Leer lassen wenn nicht benötigt)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Externe APIs (Standard-Werte lassen)
LANGUAGE_TOOL_API_URL=https://api.languagetool.org
TATOEBA_API_URL=https://tatoeba.org/api
WIKTIONARY_API_URL=https://en.wiktionary.org/api
# Secure Cookies: In Production mit HTTPS zwingend auf true!
AUTH_SECURE_COOKIES=true

# Übersetzung (LibreTranslate — internes Docker-Netzwerk)
LIBRETRANSLATE_URL=http://libretranslate:5000
TRANSLATION_PROVIDER=libretranslate
