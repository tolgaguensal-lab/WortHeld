# LanguageTool – Open-Source Grammatik-Prüfung
# Docs: https://languagetool.org/http-api/
LT_SERVER_URL="http://languagetool:8010"
LT_MAX_TEXT_LENGTH=50000
LT_DEFAULT_LANG=de-DE

# Piper TTS – Open-Source Sprachsynthese
# Docs: https://github.com/rhasspy/piper
PIPER_TTS_URL="http://piper-tts:5002"
PIPER_VOICE=de_DE-thorsten-medium

# Externe Content-APIs (kostenlos, keine Keys nötig)
WIKTIONARY_API_URL="https://de.wiktionary.org/api/rest_v1"
TATOEBA_API_URL="https://tatoeba.org/deu/api_v0"
OPENTHESAURUS_API_URL="https://www.openthesaurus.de/synonyme"
